import tkinter as tk
from tkinter import scrolledtext
import itertools
import random
import time


# Часть 1: Формирование всех возможных трио

def algorithmic_method(musicians):
    """Алгоритмический метод формирования трио."""

    trios = []

    N = len(musicians)

    for i in range(N):

        for j in range(i + 1, N):

            for k in range(j + 1, N):

                trio = (
                    musicians[i],
                    musicians[j],
                    musicians[k]
                )

                trios.append(trio)

    return trios


def python_method(musicians):
    """Метод с использованием itertools."""

    return list(
        itertools.combinations(
            musicians,
            3
        )
    )


# Часть 2: Целевая функция

def objective_function(trios):
    """Поиск лучшего трио."""

    best_trio = None
    best_average_skill = 0

    for trio in trios:

        total_skill = (
            trio[0][2] +
            trio[1][2] +
            trio[2][2]
        )

        average_skill = total_skill / 3

        if average_skill > best_average_skill:

            best_average_skill = average_skill
            best_trio = trio

    return best_trio, best_average_skill


# Функция для обработки нажатия кнопки

def calculate_trios():

    try:

        # Получение данных из текстового поля

        input_text = input_field.get("1.0", "end-1c").strip()

        lines = input_text.split("\n")

        K = int(lines[0].strip())

        T = int(lines[1].strip())

        # Формирование списка музыкантов

        musicians = []

        for i in range(K):

            instrument_type = (i % T) + 1

            skill = random.randint(1, 10)

            musicians.append(
                (i + 1, instrument_type, skill)
            )

        # Отбор музыкантов

        filtered_musicians = []

        for m in musicians:

            if m[2] >= 5:

                filtered_musicians.append(m)

        # Формирование трио

        start1 = time.perf_counter()

        all_trios_algo = algorithmic_method(
            filtered_musicians
        )

        end1 = time.perf_counter()

        algo_time = end1 - start1

        start2 = time.perf_counter()

        all_trios_python = python_method(
            filtered_musicians
        )

        end2 = time.perf_counter()

        python_time = end2 - start2

        # Поиск оптимального трио

        best_trio, best_average = (
            objective_function(
                all_trios_python
            )
        )

        # Формирование результата

        result = (
            f"Музыканты:\n"
            + "\n".join(str(m) for m in musicians)

            + f"\n\nМузыканты после отбора:\n"
            + "\n".join(str(m) for m in filtered_musicians)

            + f"\n\nАлгоритмический способ ({len(all_trios_algo)}):\n"
            + "\n".join(str(trio) for trio in all_trios_algo)

            + f"\n\nВремя выполнения: {algo_time:.6f} сек"

            + f"\n\nСпособ itertools ({len(all_trios_python)}):\n"
            + "\n".join(str(trio) for trio in all_trios_python)

            + f"\n\nВремя выполнения: {python_time:.6f} сек"

            + f"\n\nЛучшее трио:\n"
            + "\n".join(str(m) for m in best_trio)

            + f"\n\nСреднее мастерство: {best_average:.2f}"
        )

        # Вывод результата

        output_field.delete("1.0", "end")

        output_field.insert("1.0", result)

    except Exception as e:

        output_field.delete("1.0", "end")

        output_field.insert(
            "1.0",
            f"Ошибка: {str(e)}"
        )


# Создание главного окна

root = tk.Tk()

root.title("Музыкальные трио")


# Окно ввода

input_label = tk.Label(
    root,
    text=(
        "Введите:\n"
        "K - количество музыкантов\n"
        "T - количество типов инструментов"
    ),
    justify="left",
    font=("Arial", 12)
)

input_label.pack(pady=10)

input_field = tk.Text(
    root,
    height=5,
    width=50
)

input_field.pack(pady=5)


# Кнопка для запуска вычислений

calculate_button = tk.Button(
    root,
    text="Вычислить",
    command=calculate_trios
)

calculate_button.pack(pady=10)


# Окно вывода с прокруткой

output_label = tk.Label(
    root,
    text="Результат:",
    font=("Arial", 12)
)

output_label.pack(pady=5)

output_field = scrolledtext.ScrolledText(
    root,
    height=15,
    width=70
)

output_field.pack(pady=5)


# Запуск главного цикла

root.mainloop()
